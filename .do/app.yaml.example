name: ridemates
region: sfo

envs:
  - key: DATABASE_URL
    type: SECRET
    value: "REPLACE_WITH_DOCTL_DATABASES_CONNECTION_URI"
  - key: GRADIENT_MODEL_ACCESS_KEY
    type: SECRET
    value: "REPLACE_WITH_GRADIENT_ACCESS_KEY"

services:
  - name: backend
    github:
      repo: ASM-79/Ridemates
      branch: main
      deploy_on_push: true
    source_dir: backend
    environment_slug: node-js
    # --include=dev is required: DO's buildpack sets NODE_ENV=production
    # during the build step, which makes a plain `npm install` skip
    # devDependencies (typescript/tsc) needed to run the build.
    build_command: npm install --include=dev && npm run build
    run_command: npm start
    http_port: 8080
    instance_size_slug: basic-xxs
    instance_count: 1
    envs:
      - key: JWT_SECRET
        type: SECRET
        value: "REPLACE_WITH_RANDOM_HEX_SECRET"
      - key: FRONTEND_URL
        type: GENERAL
        value: "${frontend.PUBLIC_URL}"
      - key: NODE_ENV
        type: GENERAL
        scope: RUN_TIME
        value: "production"
    health_check:
      http_path: /health

  - name: frontend
    github:
      repo: ASM-79/Ridemates
      branch: main
      deploy_on_push: true
    source_dir: frontend
    environment_slug: node-js
    build_command: npm install --include=dev && npm run build
    run_command: npm start
    http_port: 8080
    instance_size_slug: basic-xxs
    instance_count: 1
    envs:
      - key: NEXT_PUBLIC_API_URL
        type: GENERAL
        scope: RUN_AND_BUILD_TIME
        value: "${backend.PUBLIC_URL}"

ingress:
  rules:
    - match:
        path:
          prefix: /api
      component:
        name: backend
    - match:
        path:
          prefix: /
      component:
        name: frontend
